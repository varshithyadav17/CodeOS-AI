# =========================================================
# CodeOS AI - .gitignore
# =========================================================

# =========================================================
# IDEs & Editors
# =========================================================
.vscode/
.idea/
*.code-workspace

# =========================================================
# Node.js
# =========================================================
node_modules/
**/node_modules/

.npm/
npm-cache/
.pnpm-store/

.pnp
.pnp.js

.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
!.yarn/install-state.gz

# =========================================================
# Vite / React
# =========================================================
dist/
build/
.next/
out/
vite.svg

# =========================================================
# Python
# =========================================================
__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/

.coverage
coverage.xml
htmlcov/

*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# =========================================================
# Environment Variables
# =========================================================
.env
.env.local
.env.*.local

backend/.env
frontend/.env

!.env.example

# =========================================================
# Logs
# =========================================================
*.log
logs/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =========================================================
# Database Files
# =========================================================
*.db
*.sqlite
*.sqlite3

# =========================================================
# Secrets
# =========================================================
*credentials.json*
*token.json*

secrets.json
service-account.json
google-service-account.json
firebase-adminsdk*.json

*.pem

# =========================================================
# Build Cache
# =========================================================
.cache/

# =========================================================
# Temporary Files
# =========================================================
tmp/
temp/

# =========================================================
# OS Files
# =========================================================
.DS_Store
Thumbs.db
Desktop.ini

# =========================================================
# Jupyter
# =========================================================
.ipynb_checkpoints/

# =========================================================
# Deployment
# =========================================================
.vercel/

# Docker
docker-compose.override.yml

# Terraform
.terraform/
*.tfstate
*.tfstate.*

# =========================================================
# Generated Data
# =========================================================
uploads/
storage/
generated/
artifacts/

# =========================================================
# Test Reports
# =========================================================
coverage/
test_reports/
reports/

# =========================================================
# Project-specific
# =========================================================
chainlit.md
.chainlit
.ac

memory/test_credentials.md

agenthub/agents/youtube/db

# =========================================================
# Archives
# =========================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.pack
*.deb
*.dylib